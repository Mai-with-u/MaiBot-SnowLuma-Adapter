{
  "manifest_version": 2,
  "version": "0.8.1",
  "name": "SnowLuma 连接器（适配器）/ SnowLuma Adapter",
  "description": "连接SnowLuma的Maibot连接器/SnowLuma WebSocket adapter plugin for MaiBot message gateway.",
  "author": {
    "name": "MaiBot Team",
    "url": "https://github.com/Mai-with-u/MaiBot-SnowLuma-Adapter"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/Mai-with-u/MaiBot-SnowLuma-Adapter",
    "homepage": "https://github.com/Mai-with-u/MaiBot-SnowLuma-Adapter",
    "documentation": "https://github.com/Mai-with-u/MaiBot-SnowLuma-Adapter",
    "issues": "https://github.com/Mai-with-u/MaiBot-SnowLuma-Adapter/issues"
  },
  "plugin_type":"adapter",
  "display": {
    "icon":{
      "type": "local",
      "value": "assets/icon.jpg"
    }
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "silk-python",
      "version_spec": ">=0.2.8"
    }
  ],
  "capabilities": [
    "chat.open_session",
    "component.disable",
    "component.enable",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "maibot-team.snowluma-adapter"
}
